# Example env file for hermes-market-skills.
# Copy to ~/.agent/credentials/market-skills.env (chmod 600) and fill in.
# ALL keys are optional. Skills fall back to anonymous/free endpoints when blank,
# at the cost of lower rate limits.

# ---- Crypto skill ----
# https://www.coingecko.com/en/api/pricing  — Demo plan free, 30 calls/min, ~10k/month
COINGECKO_API_KEY=

# https://cryptopanic.com/developers/api/  — free 200 calls/day
CRYPTOPANIC_API_KEY=

# ---- Saham IDN skill ----
# (none required — yfinance + RSS are anonymous)

# ---- Forex / Commodities skill ----
# https://twelvedata.com/pricing  — Basic free 800 calls/day, 8/min
TWELVEDATA_API_KEY=

# Optional: alternate forex feed if TwelveData quota exhausted
# https://exchangerate-api.com  — free 1500 calls/month
EXCHANGERATE_API_KEY=

# ---- Optional: Hermes LLM (for narrative analysis) ----
# Pointed at 9router locally; defaults match Hermes config.
NINEROUTER_BASE_URL=http://localhost:20128/v1
NINEROUTER_API_KEY=
HERMES_MODEL=jagrescombo
